 
{
    "manifest_version": 3,
    "name": "Autofill Extension",
    "version": "1.0",
    "description": "An extension to autofill forms with predefined data.",
    "permissions": [
        "activeTab",
        "storage",
        "scripting"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Autofill Extension",
        "default_icon": {
        "16": "icons/icon16.png"
        
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
                "matches": [
                    "https://ptc.eightfold.ai/careers/apply*",
                    "https://ptc.eightfold.ai/careers/apply/*"
                ],
        "js": ["content.js"]
        }
    ],
     "web_accessible_resources": [
    {
      "resources": ["data.json"],
      "matches":    ["*://*.eightfold.ai/*"]
    }
  ]
}